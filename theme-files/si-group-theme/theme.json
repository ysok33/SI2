{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary",        "color": "#1A3A5C", "name": "Primary Navy" },
        { "slug": "accent-gold",    "color": "#C8A96E", "name": "Accent Gold" },
        { "slug": "surface",        "color": "#F5F4F2", "name": "Surface" },
        { "slug": "surface-blue",   "color": "#E8EDF2", "name": "Surface Blue" },
        { "slug": "text-main",      "color": "#1A1A1A", "name": "Text Main" },
        { "slug": "text-sub",       "color": "#555555", "name": "Text Sub" },
        { "slug": "white",          "color": "#FFFFFF", "name": "White" },
        { "slug": "border",         "color": "#E0E0E0", "name": "Border" }
      ],
      "defaultPalette": false
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Noto Sans JP', sans-serif",
          "slug": "noto-sans-jp",
          "name": "Noto Sans JP",
          "fontFace": [
            { "fontFamily": "Noto Sans JP", "fontWeight": "400", "fontStyle": "normal", "src": ["https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900"] }
          ]
        },
        {
          "fontFamily": "'Noto Serif JP', serif",
          "slug": "noto-serif-jp",
          "name": "Noto Serif JP",
          "fontFace": [
            { "fontFamily": "Noto Serif JP", "fontWeight": "700", "fontStyle": "normal", "src": ["https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@700"] }
          ]
        },
        {
          "fontFamily": "'Barlow Condensed', sans-serif",
          "slug": "barlow-condensed",
          "name": "Barlow Condensed",
          "fontFace": [
            { "fontFamily": "Barlow Condensed", "fontWeight": "600", "fontStyle": "normal", "src": ["https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600"] }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "size": "14px", "name": "XS" },
        { "slug": "sm",   "size": "16px", "name": "SM" },
        { "slug": "md",   "size": "20px", "name": "MD" },
        { "slug": "lg",   "size": "28px", "name": "LG" },
        { "slug": "xl",   "size": "36px", "name": "XL" },
        { "slug": "xxl",  "size": "48px", "name": "XXL" }
      ],
      "defaultFontSizes": false
    },
    "spacing": {
      "spacingScale": { "steps": 0 },
      "spacingSizes": [
        { "slug": "section-sm", "size": "48px",  "name": "Section SM" },
        { "slug": "section-md", "size": "80px",  "name": "Section MD" },
        { "slug": "section-lg", "size": "120px", "name": "Section LG" }
      ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },
    "custom": {
      "border-radius": {
        "card":   "8px",
        "button": "4px",
        "badge":  "24px"
      },
      "shadow": {
        "card": "0 2px 12px rgba(0,0,0,0.08)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "#FFFFFF",
      "text": "#1A1A1A"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--noto-sans-jp)",
      "fontSize":   "var(--wp--preset--font-size--sm)",
      "lineHeight": "1.8"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily":  "var(--wp--preset--font-family--noto-serif-jp)",
          "fontSize":    "var(--wp--preset--font-size--xxl)",
          "fontWeight":  "700",
          "lineHeight":  "1.3"
        }
      },
      "h2": {
        "typography": {
          "fontFamily":  "var(--wp--preset--font-family--noto-serif-jp)",
          "fontSize":    "var(--wp--preset--font-size--lg)",
          "fontWeight":  "700",
          "lineHeight":  "1.3"
        }
      },
      "h3": {
        "typography": {
          "fontFamily":  "var(--wp--preset--font-family--noto-sans-jp)",
          "fontSize":    "var(--wp--preset--font-size--md)",
          "fontWeight":  "700",
          "lineHeight":  "1.4"
        }
      },
      "link": {
        "color": { "text": "#1A3A5C" },
        ":hover": { "color": { "text": "#C8A96E" } }
      },
      "button": {
        "color": {
          "background": "#1A3A5C",
          "text":       "#FFFFFF"
        },
        "typography": {
          "fontSize":    "var(--wp--preset--font-size--sm)",
          "fontWeight":  "700"
        },
        "border": { "radius": "4px" },
        ":hover": {
          "color": { "background": "#0F2540" }
        }
      }
    }
  },
  "templateParts": [
    { "area": "header", "name": "header", "title": "Header" },
    { "area": "footer", "name": "footer", "title": "Footer" }
  ],
  "customTemplates": [
    { "name": "front-page", "title": "Front Page", "postTypes": ["page"] }
  ]
}