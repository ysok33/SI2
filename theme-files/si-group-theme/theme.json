{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary", "color": "#1A4FA0", "name": "Primary Blue" },
        { "slug": "background", "color": "#FFFFFF", "name": "White" },
        { "slug": "surface", "color": "#F5F4F2", "name": "Off White" },
        { "slug": "text", "color": "#1A1A1A", "name": "Dark Text" },
        { "slug": "muted", "color": "#F0F0F0", "name": "Light Gray" },
        { "slug": "accent-light", "color": "#EBF0FA", "name": "Accent Light Blue" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Noto Serif JP', serif",
          "slug": "heading",
          "name": "Noto Serif JP",
          "fontFace": [
            {
              "fontFamily": "Noto Serif JP",
              "fontWeight": "600 700",
              "fontStyle": "normal",
              "src": ["https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@600;700&display=swap"]
            }
          ]
        },
        {
          "fontFamily": "'Noto Sans JP', sans-serif",
          "slug": "body",
          "name": "Noto Sans JP",
          "fontFace": [
            {
              "fontFamily": "Noto Sans JP",
              "fontWeight": "400 700",
              "fontStyle": "normal",
              "src": ["https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "13px", "name": "Small" },
        { "slug": "normal", "size": "16px", "name": "Normal" },
        { "slug": "medium", "size": "20px", "name": "Medium" },
        { "slug": "large", "size": "28px", "name": "Large" },
        { "slug": "x-large", "size": "36px", "name": "X Large" },
        { "slug": "xx-large", "size": "52px", "name": "XX Large" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw"],
      "spacingScale": {
        "steps": 7
      }
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "16px",
      "lineHeight": "1.8"
    },
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "lineHeight": "1.3"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "lineHeight": "1.35"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontWeight": "700"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "typography": {
            "textDecoration": "underline"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--background)"
        },
        "typography": {
          "fontWeight": "700",
          "fontSize": "16px"
        },
        "border": {
          "radius": "4px"
        },
        "spacing": {
          "padding": {
            "top": "14px",
            "bottom": "14px",
            "left": "32px",
            "right": "32px"
          }
        }
      }
    }
  }
}