{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "features": {
    "networking": true
  },
  "steps": [
    {
      "step": "installTheme",
      "themeData": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/ysok33/SI2/main/si-group-theme.zip"
      }
    },
    {
      "step": "activateTheme",
      "themeFolderName": "si-group-theme"
    },
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "SIgroup\u682a\u5f0f\u4f1a\u793e",
        "blogdescription": "\u4eba\u6750\u6d3e\u9063\u30fb\u8077\u696d\u7d39\u4ecb\u30fb\u901a\u4fe1\u30fb\u30a4\u30d9\u30f3\u30c8\u4e8b\u696d",
        "show_on_front": "page"
      }
    }
  ]
}