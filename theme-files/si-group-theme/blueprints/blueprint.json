    {
      "step": "runPHP",
      "code": "<?php require '/wordpress/wp-load.php'; $pages = [ ['post_title'=>'会社概要','post_name'=>'company','post_content'=>'<!-- wp:paragraph --><p>会社概要ページは準備中です。</p><!-- /wp:paragraph -->'], ['post_title'=>'事業内容','post_name'=>'services','post_content'=>'<!-- wp:paragraph --><p>事業内容ページは準備中です。</p><!-- /wp:paragraph -->'], ['post_title'=>'採用情報','post_name'=>'recruit','post_content'=>'<!-- wp:paragraph --><p>採用情報ページは準備中です。</p><!-- /wp:paragraph -->'], ['post_title'=>'お問い合わせ','post_name'=>'contact','post_content'=>'<!-- wp:paragraph --><p>お問い合わせページは準備中です。</p><!-- /wp:paragraph -->'], ['post_title'=>'プライバシーポリシー','post_name'=>'privacy-policy','post_content'=>'<!-- wp:paragraph --><p>プライバシーポリシーページは準備中です。</p><!-- /wp:paragraph -->'] ]; foreach($pages as $p){ if(!get_page_by_path($p['post_name'])){ wp_insert_post(['post_title'=>$p['post_title'],'post_name'=>$p['post_name'],'post_content'=>$p['post_content'],'post_status'=>'publish','post_type'=>'page']); } } echo 'Pages created.'; ?>"
    }
